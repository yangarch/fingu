# Strava
STRAVA_CLIENT_ID=your_client_id
STRAVA_CLIENT_SECRET=your_client_secret
STRAVA_VERIFY_TOKEN=your_random_verify_token

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Server
BASE_URL=https://your-server-url.com
PORT=3003

# Database
DATABASE_URL=/app/data/swim-analyzer.db

# Notifications (optional) — Discord or Slack incoming webhook for failure alerts.
# Leave unset to disable.
NOTIFICATION_WEBHOOK_URL=

# Admin (optional) — token guarding POST /admin/backfill.
# Falls back to STRAVA_VERIFY_TOKEN when unset.
ADMIN_TOKEN=
